# Application Settings
SAVER_BACKEND_HOST=0.0.0.0
SAVER_BACKEND_PORT=8000
SAVER_BACKEND_WORKERS_COUNT=1
SAVER_BACKEND_RELOAD=True
SAVER_BACKEND_ENVIRONMENT=local

# Sentry Configuration (Optional)
SAVER_BACKEND_SENTRY_DSN=
SAVER_BACKEND_SENTRY_SAMPLE_RATE=1.0

# Telegram Bot Configuration
SAVER_BACKEND_TELEGRAM_BOT_TOKEN=your_bot_token_here
SAVER_BACKEND_TELEGRAM_SECRET_TOKEN=your_secret_token_here
SAVER_BACKEND_SUBSCRIPTION_CHANNELS=["@channel1","@channel2"]
SAVER_BACKEND_ADMIN_CHAT_ID=-1001234567890

# VK settings
SAVER_BACKEND_VK_SERVICE_TOKEN=['vk_token']
# Yandex music settings
SAVER_BACKEND_YM_TOKEN='ym_token'

# Downloader Settings
SAVER_BACKEND_PROXIES=[]

# Docker-specific variables (for docker-compose only)
SAVER_BACKEND_VERSION=latest
NGINX_PORT=80

# Host UID/GID baked into the prod image's `app` user so bind-mounted
# ./cookies and ./downloads are writable from inside the container without
# host-side chown. On most hosts these match the deploy user; check with
# `id -u` / `id -g`. Leave defaults if your deploy user is UID/GID 1000.
APP_UID=1000
APP_GID=1000

# Telegram Bot API server credentials (https://my.telegram.org/apps)
# Used by the self-hosted aiogram/telegram-bot-api container
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
