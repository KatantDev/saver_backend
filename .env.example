# Application Settings
SAVER_BACKEND_HOST=0.0.0.0
SAVER_BACKEND_PORT=8000
SAVER_BACKEND_WORKERS_COUNT=1
SAVER_BACKEND_RELOAD=False
SAVER_BACKEND_ENVIRONMENT=local
SAVER_BACKEND_LOG_LEVEL=INFO

# Database Configuration
SAVER_BACKEND_DB_HOST=localhost
SAVER_BACKEND_DB_PORT=5432
SAVER_BACKEND_DB_USER=saver_backend
SAVER_BACKEND_DB_PASS=saver_backend
SAVER_BACKEND_DB_BASE=saver_backend
SAVER_BACKEND_DB_ECHO=False

# Redis Configuration
SAVER_BACKEND_REDIS_HOST=localhost
SAVER_BACKEND_REDIS_PORT=6379
SAVER_BACKEND_REDIS_USER=
SAVER_BACKEND_REDIS_PASS=
SAVER_BACKEND_REDIS_BASE=

# Sentry Configuration (Optional)
SAVER_BACKEND_SENTRY_DSN=
SAVER_BACKEND_SENTRY_SAMPLE_RATE=1.0

# Telegram Bot Configuration
SAVER_BACKEND_TELEGRAM_BOT_TOKEN=your_bot_token_here
SAVER_BACKEND_TELEGRAM_SECRET_TOKEN=your_secret_token_here
SAVER_BACKEND_SUBSCRIPTION_CHANNELS=["@channel1","@channel2"]
SAVER_BACKEND_ADMIN_CHAT_ID=-1001234567890
SAVER_BACKEND_INSTAGRAM_ACCOUNTS=["username1:password1","username2:password2"]

# Telegram Bot API (for local bot api server)
SAVER_BACKEND_TELEGRAM_BOT_API_URL=http://localhost:8081

# Webhook Configuration
SAVER_BACKEND_WEBHOOK_BASE_URL=https://yourdomain.com/api/webhook
SAVER_BACKEND_WEBHOOK_TELEGRAM_PATH=/telegram

# Downloader Settings
SAVER_BACKEND_PROXIES=[]

# Docker-specific variables (for docker-compose only)
SAVER_BACKEND_VERSION=latest
NGINX_PORT=80
