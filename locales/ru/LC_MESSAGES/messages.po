#: saver_backend/telegram_bot/handlers/download.py:130
#: saver_backend/telegram_bot/handlers/download.py:191
msgid "Selection time expired. Please send the link again."
msgstr "Время выбора истекло. Пожалуйста, отправьте ссылку заново."

#: saver_backend/telegram_bot/handlers/download.py:139
#, python-brace-format
msgid ""
"<b>{title}</b>\n"
"\n"
"Multiple audio tracks are available for quality {label}. Please select the language:"
msgstr ""
"<b>{title}</b>\n"
"\n"
"Для качества {label} доступно несколько аудиодорожек. Выберите язык:"

