msgid "failed to get video info"
msgstr "Не удалось получить информацию о видео."

#: saver_backend/task_manager/tasks.py:112
msgid "No formats available for download."
msgstr "Не найдено доступных форматов для скачивания."

#: saver_backend/task_manager/tasks.py:122
msgid "choose quality"
msgstr ""
"<b>{title}</b>\n"
"\n"
"Выберите желаемое качество:"

