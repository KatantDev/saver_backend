#: saver_backend/services/telegram/bot_controller.py:248
#: saver_backend/telegram_bot/handlers/start.py:66
msgid "welcome message"
msgstr ""
"<b>🎬 Этот бот создан, чтобы скачивать видео из:</b> YouTube | TikTok | Instagram | ВКонтакте\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>Бот — полностью бесплатный.</b>.\n"
"Чтобы пользоваться им — просто подпишитесь на два наших канала:"

#: saver_backend/services/telegram/bot_controller.py:311
#: saver_backend/services/telegram/bot_controller.py:362
#: saver_backend/services/telegram/bot_controller.py:415
#: saver_backend/services/telegram/bot_controller.py:462
msgid "result direct message"
msgstr ""
"{url}\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> @saver"

#: saver_backend/services/telegram/bot_controller.py:495
msgid "tiktok photo unsupported"
msgstr "Скачивание фото не поддерживается для TikTok прямо сейчас, но мы уже работаем над его поддержкой."

#: saver_backend/services/telegram/bot_controller.py:512
msgid "error downloading"
msgstr ""
"<b>Произошла ошибка при скачивании видео.</b>\n"
"Ошибка отправлена нашим разработчикам, мы исправим её в ближайшее время."

#: saver_backend/services/telegram/bot_controller.py:543
msgid "failed to get video info"
msgstr "Не удалось получить информацию о видео."

#: saver_backend/services/telegram/bot_controller.py:561
msgid "video info without formats"
msgstr "Не найдено доступных форматов для скачивания. Пожалуйста, попробуйте ещё раз позже."

#: saver_backend/services/telegram/bot_controller.py:586
#: saver_backend/services/telegram/bot_controller.py:597
msgid "choose quality"
msgstr ""
"<b>{title}</b>\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> Выберите желаемое качество:"

#: saver_backend/telegram_bot/handlers/download.py:47
msgid "unknown url"
msgstr ""
"Эта ссылка не поддерживается для скачивания.\n"
"Но мы уже работаем над её поддержкой."

#: saver_backend/telegram_bot/handlers/download.py:95
msgid "get video info"
msgstr "🔍 Получаю информацию о видео... Это может занять порядка 5 секунд."

#: saver_backend/telegram_bot/handlers/download.py:122
#: saver_backend/telegram_bot/handlers/download.py:179
msgid "format selection expired"
msgstr "Время выбора истекло. Пожалуйста, отправьте ссылку заново."

#: saver_backend/telegram_bot/handlers/download.py:129
msgid "choose language for download"
msgstr ""
"<b>{title}</b>\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> Выберите желаемый язык:"

#: saver_backend/telegram_bot/handlers/download.py:151
#: saver_backend/telegram_bot/handlers/download.py:186
msgid "format not found"
msgstr "Произошла ошибка, формат не найден. Пожалуйста, попробуйте ещё раз."

#: saver_backend/telegram_bot/handlers/start.py:91
#: saver_backend/telegram_bot/handlers/subscribe.py:36
msgid "information message"
msgstr ""
"<b>🎬 Этот бот создан, чтобы скачивать видео из:</b> YouTube | TikTok | Instagram | ВКонтакте\n"
"\n"
"<tg-emoji emoji-id=\"5906762234633130643\">🔗</tg-emoji> Просто отправьте ссылку на видео — и бот сразу пришлёт файл для скачивания.\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>Также работает в инлайн-режиме:</b> откройте любой чат, введите @saver и вставьте ссылку."

#: saver_backend/telegram_bot/handlers/start.py:95
msgid "not subscribed to channels"
msgstr "⚠️ Вы не подписаны на каналы"

#: saver_backend/telegram_bot/handlers/subscribe.py:19
msgid "left from channels"
msgstr ""
"🎬 Мы обнаружили, что вы <b>не подписаны</b> на наши каналы\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>Бот — полностью бесплатный.</b>.\n"
"Чтобы пользоваться им — просто подпишитесь на два наших канала:"

#: saver_backend/telegram_bot/keyboards/inline.py:49
msgid "subscribe to channel"
msgstr "➕ Подписаться на @{channel}"

#: saver_backend/telegram_bot/keyboards/inline.py:52
msgid "check subscriptions"
msgstr "✅ Проверить подписки"

