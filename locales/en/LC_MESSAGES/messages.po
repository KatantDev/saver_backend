#: saver_backend/services/telegram/bot_controller.py:262
#: saver_backend/telegram_bot/handlers/start.py:33
msgid "welcome message"
msgstr ""
"<b>🎬 This bot is created to download videos from:</b> YouTube | TikTok | Instagram | VKontakte\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>This bot is completely free.</b>.\n"
"To use it - just subscribe to two of our channels:"

#: saver_backend/services/telegram/bot_controller.py:366
#: saver_backend/services/telegram/bot_controller.py:397
#: saver_backend/services/telegram/bot_controller.py:503
#: saver_backend/services/telegram/bot_controller.py:550
#: saver_backend/services/telegram/bot_controller.py:596
#: saver_backend/services/telegram/bot_controller.py:653
#: saver_backend/services/telegram/bot_controller.py:700
msgid "result direct message"
msgstr ""
"{url}\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> @saver"

#: saver_backend/services/telegram/bot_controller.py:417
#: saver_backend/services/telegram/bot_controller.py:767
msgid "error downloading"
msgstr ""
"<b>An error occurred while downloading the video.</b>\n"
"The error has been sent to our developers, we will fix it as soon as possible."

#: saver_backend/services/telegram/bot_controller.py:421
msgid "error inline query"
msgstr "Something went wrong, while downloading video"

#: saver_backend/services/telegram/bot_controller.py:733
msgid "video is private"
msgstr "This video is private."

#: saver_backend/services/telegram/bot_controller.py:750
msgid "tiktok photo unsupported"
msgstr "Photo downloading is not supported for TikTok right now, but we are already working on it."

#: saver_backend/services/telegram/bot_controller.py:800
msgid "failed to get video info"
msgstr "Failed to get video information."

#: saver_backend/services/telegram/bot_controller.py:820
msgid "video info without formats"
msgstr "No formats available for download. Please try again later."

#: saver_backend/services/telegram/bot_controller.py:846
#: saver_backend/services/telegram/bot_controller.py:864
msgid "choose quality"
msgstr ""
"<b>{title}</b>\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> Choose desired quality:"

#: saver_backend/task_manager/tasks.py:110
msgid "tiktok photo unsupported in inline query"
msgstr "Photo downloading is not supported in inline mode"

#: saver_backend/task_manager/tasks.py:139
msgid "inline mode blocked error"
msgstr "To use inline mode, please start or unblock the bot."

#: saver_backend/telegram_bot/handlers/download.py:51
msgid "unknown url"
msgstr ""
"This URL is not supported for downloading.\n"
"But we are already working on its support."

#: saver_backend/telegram_bot/handlers/download.py:128
msgid "get video info"
msgstr "🔍 Getting video info... This may take about 5 seconds."

#: saver_backend/telegram_bot/handlers/download.py:158
#: saver_backend/telegram_bot/handlers/download.py:213
msgid "format selection expired"
msgstr "Selection time expired. Please send the link again."

#: saver_backend/telegram_bot/handlers/download.py:166
msgid "choose language for download"
msgstr ""
"<b>{title}</b>\n"
"\n"
"<tg-emoji emoji-id=\"5785193215384623157\">🔗</tg-emoji> Choose desired language:"

#: saver_backend/telegram_bot/handlers/download.py:184
#: saver_backend/telegram_bot/handlers/download.py:221
msgid "format not found"
msgstr "An error occurred, the format was not found. Please try again."

#: saver_backend/telegram_bot/handlers/start.py:58
#: saver_backend/telegram_bot/handlers/subscribe.py:36
msgid "information message"
msgstr ""
"<b>🎬 This bot is created to download videos from:</b> YouTube | TikTok | Instagram | VKontakte\n"
"\n"
"<tg-emoji emoji-id=\"5906762234633130643\">🔗</tg-emoji> Simply send a link to the video - and the bot will immediately send a file for download.\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>Also works in inline mode:</b> open any chat, enter @saver and insert the link."

#: saver_backend/telegram_bot/handlers/start.py:62
msgid "not subscribed to channels"
msgstr "⚠️ You are not subscribed to channels"

#: saver_backend/telegram_bot/handlers/subscribe.py:19
msgid "left from channels"
msgstr ""
"🎬 We found out that you are <b>not subscribed</b> to our channels\n"
"\n"
"<tg-emoji emoji-id=\"5848394616922969249\">⚡️</tg-emoji> <b>This bot is completely free.</b>.\n"
"To use it - just subscribe to two of our channels:"

#: saver_backend/telegram_bot/keyboards/inline.py:49
msgid "subscribe to channel"
msgstr "➕ Subscribe to @{channel}"

#: saver_backend/telegram_bot/keyboards/inline.py:52
msgid "check subscriptions"
msgstr "✅ Check subscriptions"
